#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:6
msgid "Configure traffic monitoring and view usage history from a single page."
msgstr "配置流量监控，并在单个页面查看使用历史。"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:15
msgid "Monitoring Settings"
msgstr "监控设置"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:20
msgid "Traffic Backend"
msgstr "流量后端"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:22
msgid "Normal (Real-time)"
msgstr "普通（实时）"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:23
msgid "vnStat (Historical, Delayed)"
msgstr "vnStat（历史，延迟）"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:24
msgid ""
"Normal reads live counters from /proc/net/dev. "
"vnStat reads the vnStat database which updates on its own schedule."
msgstr ""
"普通模式从 /proc/net/dev 读取实时计数器。"
"vnStat 模式从 vnStat 数据库读取，其更新有自己的计划。"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:30
msgid "View Mode"
msgstr "视图模式"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:32
msgid "Daily Usage"
msgstr "每日用量"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:33
msgid "Monthly Usage"
msgstr "每月用量"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:34
msgid "Default view shown on the Network Usage tab."
msgstr "在网络用量标签页上显示的默认视图。"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:37
msgid "Preferred Interface"
msgstr "首选接口"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:38
msgid ""
"WAN interface to track. Leave blank for auto-detection.<br>"
"<strong>Tip:</strong> If your WAN uses a dynamic name (e.g. wwan0_1) "
"it will be detected automatically when left blank."
msgstr ""
"要跟踪的 WAN 接口。留空以自动检测。<br>"
"<strong>提示：</strong>如果您的 WAN 使用动态名称（例如 wwan0_1），"
"留空时将自动检测。"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:43
msgid "Auto detect"
msgstr "自动检测"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:54
msgid "vnStat Database"
msgstr "vnStat 数据库"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:63
msgid "Location: /etc/vnstat/"
msgstr "位置：/etc/vnstat/"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:69
msgid "Reset Historical Data"
msgstr "重置历史数据"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:70
msgid "Reset Database"
msgstr "重置数据库"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:72
msgid ""
"<strong style='color:#b91c1c;'>Warning:</strong> "
"This permanently deletes all stored traffic history for every interface."
msgstr ""
"<strong style='color:#b91c1c;'>警告：</strong>"
"这将永久删除所有接口的所有已存储流量历史记录。"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:87
msgid "Are you sure? All traffic history will be permanently deleted."
msgstr "您确定吗？所有流量历史记录将被永久删除。"

#: files/usr/lib/lua/luci/model/cbi/netstat/config.lua:109
msgid "vnStat database has been reset successfully for all interfaces."
msgstr "vnStat 数据库已成功为所有接口重置。"

