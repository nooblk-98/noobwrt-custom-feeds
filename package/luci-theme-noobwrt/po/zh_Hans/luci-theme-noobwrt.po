msgstr "网络 / 流量"

msgid "NAS / Storage"
msgstr "NAS / 存储"

msgid "WiFi / Wireless"
msgstr "WiFi / 无线"

msgid "Firewall"
msgstr "防火墙"

msgid "Settings / System"
msgstr "设置 / 系统"

msgid "Terminal"
msgstr "终端"

msgid "VPN"
msgstr "VPN"

msgid "Files"
msgstr "文件"

msgid "Info / Log"
msgstr "信息 / 日志"

msgid "Order"
msgstr "排序"

msgid "Lower numbers appear first in the toolbar."
msgstr "数字越小越靠前显示。"

msgid "About"
msgstr "关于"

msgid "A clean modern LuCI theme for OpenWrt routers."
msgstr "一款简洁现代的 OpenWrt LuCI 主题。"

msgid "Developer"
msgstr "开发者"

msgid "Repository"
msgstr "代码仓库"

msgid "Contributors"
msgstr "贡献者"

msgid "View on GitHub"
msgstr "在 GitHub 上查看"

msgid "License"
msgstr "许可证"

msgid "Issues / Support"
msgstr "问题 / 支持"

msgid "Open an issue"
msgstr "提交 Issue"

msgid "Made with \u2665 for the OpenWrt community"
msgstr "用 \u2665 为 OpenWrt 社区制作"

msgid "Wallpaper uploaded! Refresh the login page to see it."
msgstr "壁纸已上传！刷新登录页面即可查看。"

msgid "Failed to save wallpaper."
msgstr "壁纸保存失败。"

msgid "Upload error: "
msgstr "上传错误："

msgid "Remove custom wallpaper and revert to default?"
msgstr "删除自定义壁纸并恢复默认？"

msgid "Reverted to default wallpaper."
msgstr "已恢复默认壁纸。"

